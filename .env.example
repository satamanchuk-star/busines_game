# ── Авторизация по заявке (скопировать в .env на сервере и заполнить) ──
# .env НЕ коммитить и никому не передавать.

# API-ключ Resend (resend.com) — отправка почты через HTTPS, не блокируется хостингом.
# Создать: resend.com → Sign Up → API Keys → Create API Key. Ключ начинается с re_
RESEND_API_KEY=

# Куда приходят заявки на доступ.
OWNER_EMAIL=satamanchuk@gmail.com

# Базовый адрес сайта — из него строятся ссылки в письме.
BASE_URL=https://ibsgame.ru

# Срок жизни cookie-доступа (дней).
AUTH_COOKIE_DAYS=30

# 1 = авторизация включена (по умолчанию), 0 = выключить гейт (локальная отладка).
AUTH_ENABLED=1

# Режим воркшопа: общий код доступа на сессию. Задать перед живой игрой и раздать
# участникам → мгновенный вход без персональных заявок (снимает затор на 30 чел).
# Пусто = режим выключен (работает только заявка+одобрение). После игры — очистить.
WORKSHOP_CODE=

# 1 = ставить cookie с флагом Secure (для HTTPS-прод). Локально по http оставить пусто/0.
COOKIE_SECURE=1
